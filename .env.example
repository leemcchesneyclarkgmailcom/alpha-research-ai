# Alpha Research AI — Environment Variables
# Copy to `.env` and override values for your deployment.

# ---- Database ----
# Local dev: SQLite (no setup needed, auto-detected by scripts/prisma-provider.ts)
# Vercel prod: PostgreSQL — use Vercel Postgres, Neon, or Supabase:
#   postgresql://user:password@host:5432/alpha_research?schema=public
DATABASE_URL="file:./db/custom.db"

# ---- App ----
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_NAME="Alpha Research AI"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Auth (NextAuth.js) ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Optional: OAuth providers (uncomment in src/lib/auth-config.ts too)
# GITHUB_ID=""
# GITHUB_SECRET=""
# GOOGLE_ID=""
# GOOGLE_SECRET=""

# ---- Vercel Cron ----
# Secret that Vercel Cron sends as Authorization: Bearer <secret>.
# Generate with: openssl rand -hex 32
# Set this in Vercel → Settings → Environment Variables.
CRON_SECRET=""

# ---- AI Provider ----
# The z-ai-web-dev-sdk auto-resolves credentials from the runtime.
# For self-hosted deployments, set:
# ZAI_API_KEY=""

# ---- Market Data (production) ----
# ALPHA_VANTAGE_API_KEY=""
# FMP_API_KEY=""
# POLYGON_API_KEY=""

# ---- SEC EDGAR ----
# SEC_USER_AGENT="Alpha Research AI contact@example.com"

# ---- News ----
# NEWSAPI_KEY=""
# GDELT_PROJECT="alpha-research"

# ---- Caching (production) ----
# REDIS_URL="redis://localhost:6379"

# ---- Queue (production) ----
# BullMQ / Redis-backed queue is auto-configured when REDIS_URL is set.

# ---- Storage ----
# S3_BUCKET="alpha-research-reports"
# S3_REGION="us-east-1"

# ---- Observability ----
# SENTRY_DSN=""
# LOG_LEVEL="info"
