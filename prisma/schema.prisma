// Alpha Research AI — Prisma schema
//
// This schema works with BOTH SQLite (local dev) and PostgreSQL (Vercel prod).
// The provider is set dynamically by scripts/prisma-provider.ts before any
// prisma command runs. See package.json scripts: db:push, db:generate, etc.
//
// To use PostgreSQL (Vercel): set DATABASE_URL=postgresql://... and the
// scripts/prisma-provider.ts helper will auto-detect and switch the provider.
// To use SQLite (local dev): set DATABASE_URL=file:./db/custom.db and the
// helper will switch to sqlite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & billing
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  image         String?
  role          String   @default("user") // user | admin
  plan          String   @default("free") // free | pro | institutional
  creditsUsed   Int      @default(0)
  creditsLimit  Int      @default(25)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  watchlists    Watchlist[]
  portfolios    Portfolio[]
  reports       ResearchReport[]
  jobs          Job[]
  conversations ChatConversation[]
  alerts        Alert[]
  sessions      Session[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Market data
// ---------------------------------------------------------------------------

model Company {
  id            String   @id @default(cuid())
  ticker        String   @unique
  name          String
  exchange      String   @default("NASDAQ")
  sector        String?
  industry      String?
  logoUrl       String?
  website       String?
  description   String?
  ceo           String?
  employees     Int?
  headquarters  String?
  marketCap     Float?
  peRatio       Float?
  eps           Float?
  dividendYield Float?
  beta          Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  prices        StockPrice[]
  financials    FinancialStatement[]
  earnings      EarningsReport[]
  filings       Filing[]
  news          NewsItem[]
  ratings       AIRating[]
  reports       ResearchReport[]
  watchlistRows WatchlistItem[]
  portfolioRows PortfolioHolding[]
  insiders      InsiderTransaction[]
  alerts        Alert[]
}

model StockPrice {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  change    Float?

  @@unique([companyId, date])
  @@index([companyId, date])
}

model FinancialStatement {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period       String
  type         String
  revenue      Float?
  grossProfit  Float?
  operatingIncome Float?
  netIncome    Float?
  eps          Float?
  totalAssets  Float?
  totalLiabilities Float?
  cash         Float?
  debt         Float?
  operatingCashFlow Float?
  capex        Float?
  freeCashFlow Float?
  createdAt    DateTime @default(now())

  @@index([companyId, period])
}

model EarningsReport {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period       String
  reportDate   DateTime
  epsActual    Float?
  epsExpected  Float?
  revenueActual Float?
  revenueExpected Float?
  surprise     Float?
  transcriptSummary String?
  keyTakeaways String?
  guidance     String?
  createdAt    DateTime @default(now())

  @@index([companyId, reportDate])
}

model Filing {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type       String
  period     String
  filedAt    DateTime
  url        String?
  summary    String?
  risks      String?
  sentiment  String?
  createdAt  DateTime @default(now())

  @@index([companyId, filedAt])
}

model NewsItem {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  headline   String
  summary    String?
  url        String?
  source     String?
  sentiment  String?
  sentimentScore Float?
  publishedAt DateTime
  createdAt  DateTime @default(now())

  @@index([companyId, publishedAt])
}

// ---------------------------------------------------------------------------
// AI output
// ---------------------------------------------------------------------------

model AIRating {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rating        String
  score         Int
  confidence    Int
  valuation     Int?
  growth        Int?
  profitability Int?
  health        Int?
  momentum      Int?
  bullCase      String?
  bearCase      String?
  thesis        String?
  risks         String?
  summary       String?
  generatedAt   DateTime @default(now())

  @@index([companyId, generatedAt])
}

model ResearchReport {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title        String
  type         String
  content      String
  rating       String?
  priceTarget  Float?
  summary      String?
  status       String   @default("published")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shares       SharedReport[]

  @@index([companyId, createdAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// User content
// ---------------------------------------------------------------------------

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  items     WatchlistItem[]

  @@index([userId])
}

model WatchlistItem {
  id           String   @id @default(cuid())
  watchlistId  String
  watchlist    Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  addedAt      DateTime @default(now())

  @@unique([watchlistId, companyId])
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  holdings  PortfolioHolding[]

  @@index([userId])
}

model PortfolioHolding {
  id          String   @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shares      Float
  avgCost     Float
  addedAt     DateTime @default(now())

  @@unique([portfolioId, companyId])
}

// ---------------------------------------------------------------------------
// Background jobs / scheduler
// ---------------------------------------------------------------------------

model Job {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  status    String   @default("queued")
  payload   String?
  result    String?
  error     String?
  createdAt DateTime @default(now())
  startedAt DateTime?
  endedAt   DateTime?

  @@index([status, createdAt])
  @@index([type])
}

model ScheduledTask {
  id        String   @id @default(cuid())
  name      String   @unique
  cron      String
  enabled   Boolean  @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// DB-backed cache (serverless-safe, replaces in-memory Map)
// ---------------------------------------------------------------------------

model CacheEntry {
  key       String   @id
  value     String
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// AI Chat Analyst — conversational Q&A per company
// ---------------------------------------------------------------------------

model ChatConversation {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  title     String       @default("New conversation")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  messages  ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id              String           @id @default(cuid())
  conversationId  String
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String
  content         String
  createdAt       DateTime         @default(now())

  @@index([conversationId, createdAt])
}

// ---------------------------------------------------------------------------
// Insider transactions
// ---------------------------------------------------------------------------

model InsiderTransaction {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  insider   String
  title     String?
  type      String
  shares    Float
  price     Float
  value     Float
  filedAt   DateTime
  createdAt DateTime @default(now())

  @@index([companyId, filedAt])
}

// ---------------------------------------------------------------------------
// User alerts — price targets, rating changes, earnings
// ---------------------------------------------------------------------------

model Alert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String
  threshold   Float?
  active      Boolean  @default(true)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, active])
  @@index([companyId])
}

// ---------------------------------------------------------------------------
// Shareable public report links
// ---------------------------------------------------------------------------

model SharedReport {
  id        String   @id @default(cuid())
  reportId  String
  report    ResearchReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime?
  createdAt DateTime @default(now())
}
