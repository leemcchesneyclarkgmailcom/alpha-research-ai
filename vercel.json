{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/process-jobs",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/collect-prices",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/collect-filings",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/collect-news",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/generate-ratings",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate-reports",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "*/5 * * * *"
    }
  ]
}
